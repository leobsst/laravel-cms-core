{
    "name": "leobsst/laravel-cms-core",
    "description": "Here's the core of my CMS for my use case",
    "homepage": "https://github.com/leobsst/laravel-cms-core",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Leobsst\\LaravelCmsCore\\": "src/"
        }
    },
    "authors": [
        {
            "name": "LEOBSST",
            "email": "contact@leobsst.fr",
            "homepage": "https://www.linksly.fr/LEOBSST",
            "role": "Developer"
        },
        {
            "name": "B.L.A.M. PRODUCTION",
            "email": "contact@blam-prod.fr",
            "homepage": "https://blam-prod.fr",
            "role": "Provider"
        }
    ],
    "require": {
        "php": "^8.2",
        "althinect/filament-spatie-roles-permissions": "3.x-dev",
        "amidesfahani/filament-tinyeditor": "^4.0",
        "laravel/framework": "^11.9",
        "filament/filament": "^4.0",
        "filament/spatie-laravel-tags-plugin": "^4.0",
        "guzzlehttp/guzzle": "^7.9",
        "intervention/image": "^3.10",
        "laravel/passport": "^12.0",
        "laravel/tinker": "^2.9",
        "league/flysystem-sftp-v3": "^3.29",
        "livewire/livewire": "*",
        "maatwebsite/excel": "^3.1",
        "spatie/laravel-pdf": "^1.5",
        "timwassenburg/laravel-service-generator": "^1.0",
        "valentin-morice/filament-json-column": "dev-dev",
        "wire-elements/modal": "^2.0",
        "laravel/pennant": "^1.18",
        "league/flysystem-aws-s3-v3": "^3.29",
        "saloonphp/xml-wrangler": "^1.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^3.7",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Leobsst\\LaravelCmsCore\\Providers\\LaravelCmsCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
